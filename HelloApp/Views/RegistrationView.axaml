<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="HelloApp.Views.RegistrationView"
             xmlns:vm="using:HelloApp.ViewModels"
             x:DataType="vm:RegistrationViewModel"> 
    <StackPanel>
		<TextBox Watermark="Login"
                 Text="{Binding User.Login}"/>
        <TextBox Watermark="Password"
                 TextInputOptions.ContentType="Password"
                 PasswordChar="*"
                 Text="{Binding User.Password}"/>
        <TextBox Watermark="Confirm password"
                 TextInputOptions.ContentType="Password"
                 PasswordChar="*"
                 Text="{Binding User.ConfirmPassword}"/>
        <TextBox Watermark="Email"
                 TextInputOptions.ContentType="Email"
                 Text="{Binding User.Email}"/>
        <TextBox Watermark="Phone"
                 TextInputOptions.ContentType="Number"
                 Text="{Binding User.Phone}"/>
    </StackPanel>
    
</UserControl>
